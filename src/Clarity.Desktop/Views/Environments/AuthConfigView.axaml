<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:suki="https://github.com/kikipoulet/SukiUI"
             xmlns:vm="clr-namespace:Clarity.Desktop.ViewModels.Environments"
             x:Class="Clarity.Desktop.Views.Environments.AuthConfigView"
             x:DataType="vm:AuthConfigViewModel">

  <ScrollViewer Padding="32,24">
    <StackPanel Spacing="12" MaxWidth="800">
      <TextBlock Text="{Binding Title}" FontSize="22" FontWeight="SemiBold"/>
      <TextBlock Text="Configure authentication for each enabled workload. Cloud workloads use Azure AD app registrations; on-premises workloads use Windows or service account credentials."
                 Foreground="{DynamicResource SukiMediumColor}" TextWrapping="Wrap" Margin="0,0,0,12"/>

      <ItemsControl ItemsSource="{Binding Workloads}" x:CompileBindings="False">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <StackPanel Spacing="4" Margin="0,0,0,12">
              <suki:GroupBox>
                <suki:GroupBox.Header>
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="{Binding WorkloadDisplayName}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Border Grid.Column="1" CornerRadius="4" Padding="8,3"
                            Background="{DynamicResource SukiLowColor}">
                      <TextBlock Text="{Binding StatusBadge}" FontSize="11" FontWeight="Medium"/>
                    </Border>
                  </Grid>
                </suki:GroupBox.Header>

                <StackPanel Spacing="14" Margin="4,8">

                  <!-- Auth type selector -->
                  <StackPanel Spacing="4">
                    <TextBlock Text="Authentication Type" FontWeight="Medium" FontSize="13"/>
                    <ComboBox ItemsSource="{Binding AvailableAuthTypes}"
                              SelectedItem="{Binding SelectedAuthTypeOption}"
                              MinWidth="260" HorizontalAlignment="Left">
                      <ComboBox.ItemTemplate>
                        <DataTemplate>
                          <StackPanel Spacing="1">
                            <TextBlock Text="{Binding DisplayName}" FontWeight="Medium"/>
                            <TextBlock Text="{Binding Description}" FontSize="11"
                                       Foreground="{DynamicResource SukiMediumColor}" TextWrapping="Wrap"/>
                          </StackPanel>
                        </DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>
                  </StackPanel>

                  <!-- ═══ CLOUD FIELDS ═══ -->
                  <StackPanel Spacing="10" IsVisible="{Binding ShowCloudFields}">
                    <StackPanel Spacing="4">
                      <TextBlock Text="Application (Client) ID" FontWeight="Medium" FontSize="13"/>
                      <TextBox Text="{Binding ClientId}" Watermark="00000000-0000-0000-0000-000000000000"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                      <TextBlock Text="Directory (Tenant) ID" FontWeight="Medium" FontSize="13"/>
                      <TextBox Text="{Binding TenantId}" Watermark="00000000-0000-0000-0000-000000000000"/>
                    </StackPanel>

                    <!-- Certificate thumbprint (Certificate auth only) -->
                    <StackPanel Spacing="4" IsVisible="{Binding ShowCertificateField}">
                      <TextBlock Text="Certificate Thumbprint" FontWeight="Medium" FontSize="13"/>
                      <TextBox Text="{Binding CertificateThumbprint}" Watermark="SHA-1 thumbprint from local certificate store"/>
                      <TextBlock Text="The certificate must be installed in the Current User or Local Machine store."
                                 FontSize="11" Foreground="{DynamicResource SukiMediumColor}" TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Secret reference (Client Secret auth only) -->
                    <StackPanel Spacing="4" IsVisible="{Binding ShowSecretField}">
                      <TextBlock Text="Secret Reference" FontWeight="Medium" FontSize="13"/>
                      <TextBox Text="{Binding SecretReference}" Watermark="Key Vault URI or DPAPI reference"
                               PasswordChar="●"/>
                      <TextBlock Text="Never store secrets in plain text. Use a Key Vault URI or DPAPI-protected reference."
                                 FontSize="11" Foreground="{DynamicResource SukiMediumColor}" TextWrapping="Wrap"/>
                    </StackPanel>
                  </StackPanel>

                  <!-- ═══ ON-PREM: WINDOWS INTEGRATED HINT ═══ -->
                  <suki:InfoBar IsOpen="{Binding ShowOnPremIntegratedHint}"
                              Severity="Information"
                              Title="Windows Integrated Authentication"
                              Message="The collector will use the current Windows session credentials (Kerberos/NTLM). Ensure you are logged in with a domain account that has read access to the target directory."
                              IsClosable="False"
                              Margin="0,4,0,0"/>

                  <!-- ═══ ON-PREM: SERVICE ACCOUNT FIELDS ═══ -->
                  <StackPanel Spacing="10" IsVisible="{Binding ShowOnPremServiceAccountFields}">
                    <StackPanel Spacing="4">
                      <TextBlock Text="Domain or Server" FontWeight="Medium" FontSize="13"/>
                      <TextBox Text="{Binding DomainOrServer}" Watermark="e.g. contoso.local or dc01.contoso.local"/>
                      <TextBlock Text="FQDN of the domain or a specific domain controller."
                                 FontSize="11" Foreground="{DynamicResource SukiMediumColor}"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                      <TextBlock Text="Username" FontWeight="Medium" FontSize="13"/>
                      <TextBox Text="{Binding Username}" Watermark="e.g. CONTOSO\svc-clarity-read"/>
                      <TextBlock Text="Use a dedicated read-only service account with minimal permissions."
                                 FontSize="11" Foreground="{DynamicResource SukiMediumColor}" TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                      <TextBlock Text="Password" FontWeight="Medium" FontSize="13"/>
                      <TextBox Text="{Binding Password}" PasswordChar="●" Watermark="Service account password"/>
                      <TextBlock Text="Password is stored using DPAPI encryption. It is never persisted in plain text."
                                 FontSize="11" Foreground="{DynamicResource SukiMediumColor}" TextWrapping="Wrap"/>
                    </StackPanel>
                  </StackPanel>

                  <!-- Save button row -->
                  <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,8,0,0">
                    <StackPanel/>
                    <ProgressBar Grid.Column="1" IsIndeterminate="True" IsVisible="{Binding IsSaving}"
                                 Width="20" Height="20" Margin="0,0,12,0"/>
                    <Button Grid.Column="2" Classes="PrimaryButton" Command="{Binding SaveCommand}"
                            IsEnabled="{Binding !IsSaving}" MinWidth="100">
                      <StackPanel Orientation="Horizontal" Spacing="6">
                        <PathIcon Data="M17 3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V7l-4-4zm-5 16c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3zm3-10H5V5h10v4z"
                                  Width="14" Height="14"/>
                        <TextBlock Text="Save" VerticalAlignment="Center"/>
                      </StackPanel>
                    </Button>
                  </Grid>
                </StackPanel>
              </suki:GroupBox>

              <!-- Success message -->
              <suki:InfoBar IsOpen="{Binding SuccessMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                          Severity="Success" Title="Saved" Message="{Binding SuccessMessage}" IsClosable="True"/>

              <!-- Error message -->
              <suki:InfoBar IsOpen="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                          Severity="Error" Title="Error" Message="{Binding ErrorMessage}" IsClosable="True"/>
            </StackPanel>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <!-- Global error -->
      <suki:InfoBar IsOpen="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                  Severity="Error" Title="Error" Message="{Binding ErrorMessage}" IsClosable="True"
                  Margin="0,8,0,0"/>
    </StackPanel>
  </ScrollViewer>
</UserControl>
