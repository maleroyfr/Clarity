<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:Clarity.Desktop.ViewModels.Shell"
        xmlns:local="clr-namespace:Clarity.Desktop"
        x:Class="Clarity.Desktop.Views.Shell.AppShell"
        x:DataType="shell:AppShellViewModel"
        Title="Clarity"
        Width="1280" Height="800"
        MinWidth="900" MinHeight="600"
        Background="{DynamicResource SystemChromeLowColor}">

  <Window.Styles>
    <StyleInclude Source="/Styles/ClarityTheme.axaml"/>
  </Window.Styles>

  <Grid x:Name="RootGrid" ColumnDefinitions="Auto,*">

    <!-- Navigation Rail -->
    <Border Grid.Column="0"
            Background="{DynamicResource SystemAltHighColor}"
            BorderBrush="{DynamicResource SystemBaseLowColor}"
            BorderThickness="0,0,1,0">
      <Grid RowDefinitions="Auto,*,Auto">

        <!-- App Logo -->
        <StackPanel Grid.Row="0" Margin="0,16,0,8" HorizontalAlignment="Center">
          <TextBlock Text="✦" FontSize="28" HorizontalAlignment="Center"
                     Foreground="{DynamicResource SystemAccentColor}"/>
          <TextBlock Text="Clarity" FontSize="11" FontWeight="SemiBold"
                     HorizontalAlignment="Center" Margin="0,4,0,0"
                     IsVisible="{Binding IsNavExpanded}"/>
        </StackPanel>

        <!-- Nav Items -->
        <ItemsControl Grid.Row="1" Margin="8,8,8,0" ItemsSource="{Binding NavItems}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="shell:NavItem" x:CompileBindings="False">
              <Button Classes="NavButton"
                      Classes.active="{Binding IsActive}"
                      Command="{Binding $parent[Window].DataContext.NavigateToCommand}"
                      CommandParameter="{Binding Section}"
                      ToolTip.Tip="{Binding Label}"
                      Margin="0,1">
                <StackPanel Orientation="Horizontal" Spacing="10">
                  <TextBlock Text="{Binding Icon}" FontSize="18" Width="24" TextAlignment="Center"/>
                  <TextBlock Text="{Binding Label}" FontSize="13"
                             IsVisible="{Binding $parent[Window].DataContext.IsNavExpanded}"
                             VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Bottom Actions -->
        <StackPanel Grid.Row="2" Margin="8,8,8,16" Spacing="2">
          <Button Classes="NavButton"
                  x:Name="AboutButton"
                  ToolTip.Tip="About Clarity">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <TextBlock Text="ℹ️" FontSize="18" Width="24" TextAlignment="Center"/>
              <TextBlock Text="About" FontSize="13" IsVisible="{Binding IsNavExpanded}" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
          <Button Classes="NavButton"
                  Command="{Binding ToggleThemeCommand}"
                  ToolTip.Tip="Toggle dark mode">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <TextBlock Text="{Binding ThemeIcon}" FontSize="18" Width="24" TextAlignment="Center"/>
              <TextBlock Text="Toggle Theme" FontSize="13" IsVisible="{Binding IsNavExpanded}" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
          <Button Classes="NavButton"
                  Command="{Binding ToggleNavCommand}"
                  ToolTip.Tip="Toggle navigation">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <TextBlock Text="◀" FontSize="14" Width="24" TextAlignment="Center"/>
              <TextBlock Text="Collapse" FontSize="13" IsVisible="{Binding IsNavExpanded}" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Page content area -->
    <ContentControl Grid.Column="1"
                    Content="{Binding CurrentPage}"
                    Margin="0">
      <ContentControl.DataTemplates>
        <local:ViewLocator/>
      </ContentControl.DataTemplates>
    </ContentControl>
  </Grid>
</Window>
