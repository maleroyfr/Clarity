<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="using:FluentAvalonia.UI.Controls"
        xmlns:shell="clr-namespace:Clarity.Desktop.ViewModels.Shell"
        xmlns:local="clr-namespace:Clarity.Desktop"
        x:Class="Clarity.Desktop.Views.Shell.AppShell"
        x:DataType="shell:AppShellViewModel"
        Title="Clarity — Audit &amp; Discovery Platform"
        Width="1360" Height="860"
        MinWidth="1024" MinHeight="680">

  <Window.Styles>
    <StyleInclude Source="/Styles/ClarityTheme.axaml"/>
  </Window.Styles>

  <ui:NavigationView x:Name="NavView"
                     PaneTitle="Clarity"
                     IsSettingsVisible="True"
                     IsPaneOpen="True"
                     IsBackButtonVisible="False"
                     PaneDisplayMode="Left"
                     SelectionChanged="NavView_SelectionChanged">

    <ui:NavigationView.MenuItems>
      <ui:NavigationViewItem Content="Home" Tag="Home"
                             IsSelected="True">
        <ui:NavigationViewItem.IconSource>
          <ui:SymbolIconSource Symbol="Home"/>
        </ui:NavigationViewItem.IconSource>
      </ui:NavigationViewItem>

      <ui:NavigationViewItemHeader Content="MANAGE"/>

      <ui:NavigationViewItem Content="Customers" Tag="Customers">
        <ui:NavigationViewItem.IconSource>
          <ui:SymbolIconSource Symbol="People"/>
        </ui:NavigationViewItem.IconSource>
      </ui:NavigationViewItem>

      <ui:NavigationViewItem Content="Environments" Tag="Environments">
        <ui:NavigationViewItem.IconSource>
          <ui:SymbolIconSource Symbol="Globe"/>
        </ui:NavigationViewItem.IconSource>
      </ui:NavigationViewItem>

      <ui:NavigationViewItem Content="Relations" Tag="Relations">
        <ui:NavigationViewItem.IconSource>
          <ui:SymbolIconSource Symbol="Link"/>
        </ui:NavigationViewItem.IconSource>
      </ui:NavigationViewItem>

      <ui:NavigationViewItemHeader Content="DISCOVER"/>

      <ui:NavigationViewItem Content="Snapshots" Tag="Snapshots">
        <ui:NavigationViewItem.IconSource>
          <ui:SymbolIconSource Symbol="Camera"/>
        </ui:NavigationViewItem.IconSource>
      </ui:NavigationViewItem>

      <ui:NavigationViewItem Content="Inventory" Tag="Inventory">
        <ui:NavigationViewItem.IconSource>
          <ui:SymbolIconSource Symbol="AllApps"/>
        </ui:NavigationViewItem.IconSource>
      </ui:NavigationViewItem>

      <ui:NavigationViewItemHeader Content="ANALYZE"/>

      <ui:NavigationViewItem Content="Comparisons" Tag="Comparisons">
        <ui:NavigationViewItem.IconSource>
          <ui:SymbolIconSource Symbol="Library"/>
        </ui:NavigationViewItem.IconSource>
      </ui:NavigationViewItem>

      <ui:NavigationViewItem Content="Exports" Tag="Exports">
        <ui:NavigationViewItem.IconSource>
          <ui:SymbolIconSource Symbol="Download"/>
        </ui:NavigationViewItem.IconSource>
      </ui:NavigationViewItem>
    </ui:NavigationView.MenuItems>

    <!-- Page content area -->
    <ContentControl Content="{Binding CurrentPage}">
      <ContentControl.DataTemplates>
        <local:ViewLocator/>
      </ContentControl.DataTemplates>
    </ContentControl>
  </ui:NavigationView>
</Window>
