<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Clarity.Desktop.ViewModels.Shell"
             x:Class="Clarity.Desktop.Views.Shell.HomeView"
             x:DataType="vm:HomeViewModel">

  <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
    <TextBlock Text="✦" FontSize="56" HorizontalAlignment="Center"
               Foreground="{DynamicResource SystemAccentColor}"/>
    <TextBlock Text="{Binding WelcomeMessage}" Classes="PageTitle" HorizontalAlignment="Center"/>
    <TextBlock Text="{Binding SubMessage}" Classes="PageSubtitle" HorizontalAlignment="Center"/>
  </StackPanel>
</UserControl>
