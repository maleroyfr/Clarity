<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:suki="https://github.com/kikipoulet/SukiUI"
             xmlns:vm="clr-namespace:Clarity.Desktop.ViewModels.Shell"
             x:Class="Clarity.Desktop.Views.Shell.SettingsView"
             x:DataType="vm:SettingsViewModel">

  <ScrollViewer Padding="32,24">
    <StackPanel Spacing="16" MaxWidth="800">
      <TextBlock Text="Settings" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,16"/>

      <!-- Appearance -->
      <suki:GroupBox Header="Appearance">
        <StackPanel Spacing="12" Margin="4">
          <StackPanel Spacing="4">
            <TextBlock Text="App Theme" FontWeight="SemiBold"/>
            <TextBlock Text="Select which app theme to display" Opacity="0.6" FontSize="12"/>
            <ComboBox SelectedIndex="{Binding ThemeIndex}" MinWidth="180"
                      ItemsSource="{Binding ThemeOptions}" Margin="0,4,0,0"/>
          </StackPanel>
          <StackPanel Spacing="4">
            <TextBlock Text="Accent Color" FontWeight="SemiBold"/>
            <TextBlock Text="Change the primary accent color" Opacity="0.6" FontSize="12"/>
            <ComboBox SelectedIndex="{Binding ColorIndex}" MinWidth="180"
                      ItemsSource="{Binding ColorOptions}" Margin="0,4,0,0"/>
          </StackPanel>
        </StackPanel>
      </suki:GroupBox>

      <!-- Data -->
      <suki:GroupBox Header="Data">
        <StackPanel Spacing="12" Margin="4">
          <DockPanel>
            <Button Content="Open folder" DockPanel.Dock="Right" VerticalAlignment="Center"
                    Command="{Binding OpenDataFolderCommand}" Margin="12,0,0,0"/>
            <StackPanel Spacing="2">
              <TextBlock Text="Database" FontWeight="SemiBold"/>
              <TextBlock Text="{Binding DatabaseInfo}" Opacity="0.6" FontSize="12"
                         TextTrimming="CharacterEllipsis"/>
            </StackPanel>
          </DockPanel>

          <Border Height="1" Opacity="0.15" Background="{DynamicResource ThemeForegroundBrush}"/>

          <DockPanel>
            <Button Content="Open folder" DockPanel.Dock="Right" VerticalAlignment="Center"
                    Command="{Binding OpenLogFolderCommand}" Margin="12,0,0,0"/>
            <StackPanel Spacing="2">
              <TextBlock Text="Logs" FontWeight="SemiBold"/>
              <TextBlock Text="{Binding LogDirectoryInfo}" Opacity="0.6" FontSize="12"
                         TextTrimming="CharacterEllipsis"/>
            </StackPanel>
          </DockPanel>
        </StackPanel>
      </suki:GroupBox>

      <!-- Keyboard Shortcuts -->
      <suki:GroupBox Header="Keyboard Shortcuts">
        <StackPanel Spacing="8" Margin="4">
          <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" Margin="0,0,0,4">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Ctrl + 1–8" FontFamily="Consolas, monospace" FontSize="12" Opacity="0.7"/>
            <TextBlock Grid.Row="0" Grid.Column="1" Text="Navigate to section" FontSize="12"/>
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Ctrl + ," FontFamily="Consolas, monospace" FontSize="12" Opacity="0.7"/>
            <TextBlock Grid.Row="1" Grid.Column="1" Text="Settings" FontSize="12"/>
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Ctrl + N" FontFamily="Consolas, monospace" FontSize="12" Opacity="0.7"/>
            <TextBlock Grid.Row="2" Grid.Column="1" Text="Create new item" FontSize="12"/>
            <TextBlock Grid.Row="3" Grid.Column="0" Text="Ctrl + B" FontFamily="Consolas, monospace" FontSize="12" Opacity="0.7"/>
            <TextBlock Grid.Row="3" Grid.Column="1" Text="Toggle sidebar" FontSize="12"/>
            <TextBlock Grid.Row="4" Grid.Column="0" Text="F5" FontFamily="Consolas, monospace" FontSize="12" Opacity="0.7"/>
            <TextBlock Grid.Row="4" Grid.Column="1" Text="Refresh current page" FontSize="12"/>
            <TextBlock Grid.Row="5" Grid.Column="0" Text="F1" FontFamily="Consolas, monospace" FontSize="12" Opacity="0.7"/>
            <TextBlock Grid.Row="5" Grid.Column="1" Text="About Clarity" FontSize="12"/>
          </Grid>
        </StackPanel>
      </suki:GroupBox>

      <!-- About -->
      <suki:GroupBox Header="About">
        <StackPanel Spacing="8" Margin="4">
          <TextBlock Text="Clarity — Audit &amp; Discovery Platform" FontWeight="SemiBold" FontSize="15"/>
          <TextBlock Text="{Binding VersionInfo, StringFormat='Version: {0}'}" Opacity="0.7"/>
          <TextBlock Text="{Binding RuntimeInfo}" Opacity="0.6" FontSize="12"/>
          <TextBlock Text="{Binding OsInfo}" Opacity="0.6" FontSize="12"/>
        </StackPanel>
      </suki:GroupBox>
    </StackPanel>
  </ScrollViewer>
</UserControl>
