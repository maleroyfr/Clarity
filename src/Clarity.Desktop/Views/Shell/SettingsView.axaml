<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             xmlns:vm="clr-namespace:Clarity.Desktop.ViewModels.Shell"
             x:Class="Clarity.Desktop.Views.Shell.SettingsView"
             x:DataType="vm:SettingsViewModel">

  <ScrollViewer Padding="32,24">
    <StackPanel Spacing="4" MaxWidth="800">
      <TextBlock Text="Settings" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,24"/>

      <!-- Appearance section -->
      <TextBlock Text="Appearance" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>

      <ui:SettingsExpander Header="App Theme"
                           Description="Select which app theme to display">
        <ui:SettingsExpander.IconSource>
          <ui:SymbolIconSource Symbol="DarkTheme"/>
        </ui:SettingsExpander.IconSource>
        <ui:SettingsExpander.Footer>
          <ComboBox SelectedIndex="{Binding ThemeIndex}" MinWidth="150">
            <ComboBoxItem Content="Use system setting"/>
            <ComboBoxItem Content="Light"/>
            <ComboBoxItem Content="Dark"/>
          </ComboBox>
        </ui:SettingsExpander.Footer>
      </ui:SettingsExpander>

      <!-- Data section -->
      <TextBlock Text="Data" FontSize="16" FontWeight="SemiBold" Margin="0,16,0,8"/>

      <ui:SettingsExpander Header="Database"
                           Description="{Binding DatabaseInfo}">
        <ui:SettingsExpander.IconSource>
          <ui:SymbolIconSource Symbol="Save"/>
        </ui:SettingsExpander.IconSource>
        <ui:SettingsExpander.Footer>
          <Button Content="Open folder" Command="{Binding OpenDataFolderCommand}"/>
        </ui:SettingsExpander.Footer>
      </ui:SettingsExpander>

      <ui:SettingsExpander Header="Logs"
                           Description="{Binding LogDirectoryInfo}">
        <ui:SettingsExpander.IconSource>
          <ui:SymbolIconSource Symbol="Document"/>
        </ui:SettingsExpander.IconSource>
        <ui:SettingsExpander.Footer>
          <Button Content="Open folder" Command="{Binding OpenLogFolderCommand}"/>
        </ui:SettingsExpander.Footer>
      </ui:SettingsExpander>

      <!-- About section -->
      <TextBlock Text="About" FontSize="16" FontWeight="SemiBold" Margin="0,16,0,8"/>

      <ui:SettingsExpander Header="Clarity — Audit &amp; Discovery Platform"
                           Description="{Binding VersionInfo}">
        <ui:SettingsExpander.IconSource>
          <ui:FontIconSource Glyph="&#xE946;" FontFamily="{StaticResource SymbolThemeFontFamily}"/>
        </ui:SettingsExpander.IconSource>
        <ui:SettingsExpanderItem Content="{Binding RuntimeInfo}"/>
        <ui:SettingsExpanderItem Content="{Binding OsInfo}"/>
      </ui:SettingsExpander>
    </StackPanel>
  </ScrollViewer>
</UserControl>
