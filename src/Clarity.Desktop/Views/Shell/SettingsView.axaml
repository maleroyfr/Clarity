<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Clarity.Desktop.ViewModels.Shell"
             x:Class="Clarity.Desktop.Views.Shell.SettingsView"
             x:DataType="vm:SettingsViewModel">
  <StackPanel Margin="24" Spacing="8">
    <TextBlock Text="{Binding Title}" Classes="PageTitle"/>
    <TextBlock Text="Settings will be available in a future release." Classes="PageSubtitle"/>
  </StackPanel>
</UserControl>
