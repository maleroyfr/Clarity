<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:suki="https://github.com/kikipoulet/SukiUI"
             xmlns:vm="clr-namespace:Clarity.Desktop.ViewModels.Onboarding"
             x:Class="Clarity.Desktop.Views.Onboarding.PrerequisitesStepView"
             x:DataType="vm:PrerequisitesStepViewModel">

  <UserControl.Styles>
    <StyleInclude Source="/Styles/ClarityTheme.axaml"/>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,Auto,Auto,*">
    <TextBlock Grid.Row="0" Text="Prerequisites" Classes="PageTitle" Margin="0,0,0,4"/>
    <TextBlock Grid.Row="1"
                Text="Verify the following prerequisites are in place. Required items must be completed; optional items enhance collection capabilities."
                Classes="PageSubtitle" Margin="0,0,0,16" TextWrapping="Wrap"/>

    <!-- Action bar -->
    <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,12">
      <TextBlock Text="{Binding StatusMessage}"
                 VerticalAlignment="Center" TextWrapping="Wrap"
                 Foreground="{DynamicResource SukiMediumColor}" FontSize="12"/>
      <Button Grid.Column="1"
              Classes="SecondaryButton"
              Content="⟳ Refresh"
              Command="{Binding RefreshCommand}"
              IsEnabled="{Binding !IsChecking}"
              Margin="0,0,8,0"/>
      <Button Grid.Column="2"
              Classes="PrimaryButton"
              Content="Install missing modules"
              Command="{Binding InstallMissingModulesCommand}"
              IsEnabled="{Binding CanInstallMissingModules}"/>
    </Grid>

    <!-- Grouped prerequisites -->
    <ScrollViewer Grid.Row="3">
      <ItemsControl ItemsSource="{Binding Groups}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:PrerequisiteGroupVm">
            <suki:GroupBox Margin="0,0,0,12">
              <suki:GroupBox.Header>
                <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                  <TextBlock Grid.Column="0" Text="{Binding GroupIcon}" FontSize="16"
                             VerticalAlignment="Center" Margin="0,0,8,0"/>
                  <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <TextBlock Text="{Binding GroupName}" FontWeight="SemiBold"/>
                      <Border IsVisible="{Binding IsOptionalGroup}"
                              Background="{DynamicResource SukiLowColor}"
                              CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                        <TextBlock Text="Optional" FontSize="10" FontWeight="Medium"/>
                      </Border>
                    </StackPanel>
                    <TextBlock Text="{Binding WorkloadHints}" FontSize="11"
                               Foreground="{DynamicResource SukiMediumColor}"
                               IsVisible="{Binding WorkloadHints, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                  </StackPanel>
                  <TextBlock Grid.Column="2" Text="{Binding CountText}" FontSize="12" FontWeight="Medium"
                             VerticalAlignment="Center" Margin="8,0,0,0"
                             Foreground="{DynamicResource SukiMediumColor}"/>
                </Grid>
              </suki:GroupBox.Header>

              <StackPanel Spacing="4" Margin="4,8">
                <TextBlock Text="{Binding GroupDescription}" FontSize="12"
                           Foreground="{DynamicResource SukiMediumColor}" TextWrapping="Wrap" Margin="0,0,0,8"/>

                <ItemsControl ItemsSource="{Binding Items}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:PrerequisiteItemVm">
                      <Border Background="{DynamicResource ClaritySubtleBackground}"
                              BorderBrush="{DynamicResource SukiLowColor}"
                              BorderThickness="1" CornerRadius="6"
                              Padding="12,8" Margin="0,0,0,4">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                          <CheckBox Grid.Column="0"
                                    IsChecked="{Binding IsCompleted}"
                                    VerticalAlignment="Top"
                                    Margin="0,0,10,0"/>
                          <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="{Binding Label}" FontWeight="Medium" FontSize="13" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding Description}" FontSize="11"
                                       Foreground="{DynamicResource SukiMediumColor}" TextWrapping="Wrap"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                              <TextBlock Text="{Binding StatusText}" FontSize="11"
                                         FontStyle="Italic" Foreground="{DynamicResource SukiMediumColor}"/>
                              <TextBlock Text="{Binding InstallScope}" FontSize="11"
                                         Foreground="{DynamicResource SukiMediumColor}"
                                         IsVisible="{Binding InstallScope, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                            </StackPanel>
                          </StackPanel>
                          <Border Grid.Column="2"
                                  IsVisible="{Binding IsOptional}"
                                  Background="{DynamicResource SukiLowColor}"
                                  CornerRadius="4" Padding="6,2"
                                  VerticalAlignment="Top" Margin="8,0,0,0">
                            <TextBlock Text="Optional" FontSize="10"/>
                          </Border>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </suki:GroupBox>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </Grid>
</UserControl>
