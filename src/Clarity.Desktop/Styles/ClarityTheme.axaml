<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Theme-aware semantic color resources (light/dark variants aligned with SukiUI) -->
  <Styles.Resources>
    <ResourceDictionary>
      <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
          <SolidColorBrush x:Key="SukiLowColor" Color="#15000000"/>
          <SolidColorBrush x:Key="SukiMediumColor" Color="#666666"/>
          <SolidColorBrush x:Key="ClaritySubtleBackground" Color="#f5f5f5"/>
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
          <SolidColorBrush x:Key="SukiLowColor" Color="#25ffffff"/>
          <SolidColorBrush x:Key="SukiMediumColor" Color="#b4b4b4"/>
          <SolidColorBrush x:Key="ClaritySubtleBackground" Color="#2a2a2a"/>
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>
    </ResourceDictionary>
  </Styles.Resources>

  <!-- Typography — SukiUI compatible resources -->
  <Style Selector="TextBlock.PageTitle">
    <Setter Property="FontSize" Value="22"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
  </Style>
  <Style Selector="TextBlock.PageSubtitle">
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="Opacity" Value="0.6"/>
  </Style>
  <Style Selector="TextBlock.SectionTitle">
    <Setter Property="FontSize" Value="16"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Margin" Value="0,16,0,8"/>
  </Style>
  <Style Selector="TextBlock.CardTitle">
    <Setter Property="FontSize" Value="15"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
  </Style>
  <Style Selector="TextBlock.CardSubtitle">
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="Opacity" Value="0.6"/>
  </Style>
  <Style Selector="TextBlock.CardMeta">
    <Setter Property="FontSize" Value="11"/>
    <Setter Property="Opacity" Value="0.4"/>
  </Style>
  <Style Selector="TextBlock.FormLabel">
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Opacity" Value="0.6"/>
    <Setter Property="Margin" Value="0,0,0,2"/>
  </Style>
  <Style Selector="TextBlock.EmptyStateTitle">
    <Setter Property="FontSize" Value="18"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="HorizontalAlignment" Value="Center"/>
  </Style>
  <Style Selector="TextBlock.EmptyStateSubtitle">
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="Opacity" Value="0.6"/>
    <Setter Property="HorizontalAlignment" Value="Center"/>
  </Style>
  <Style Selector="TextBlock.StatValue">
    <Setter Property="FontSize" Value="28"/>
    <Setter Property="FontWeight" Value="Bold"/>
  </Style>
  <Style Selector="TextBlock.StatLabel">
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="Opacity" Value="0.6"/>
  </Style>
  <Style Selector="TextBlock.KeyboardHint">
    <Setter Property="FontSize" Value="10"/>
    <Setter Property="Opacity" Value="0.35"/>
    <Setter Property="FontFamily" Value="Consolas, monospace"/>
  </Style>

  <!-- Buttons -->
  <Style Selector="Button.PrimaryButton">
    <Setter Property="Background" Value="{DynamicResource SukiPrimaryColor}"/>
    <Setter Property="Foreground" Value="White"/>
    <Setter Property="Padding" Value="16,8"/>
    <Setter Property="CornerRadius" Value="6"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Transitions">
      <Transitions>
        <DoubleTransition Property="Opacity" Duration="0:0:0.15"/>
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="Button.PrimaryButton:pointerover">
    <Setter Property="Opacity" Value="0.9"/>
  </Style>
  <Style Selector="Button.PrimaryButton:pressed">
    <Setter Property="Opacity" Value="0.75"/>
  </Style>
  <Style Selector="Button.PrimaryButton:disabled">
    <Setter Property="Opacity" Value="0.4"/>
  </Style>

  <Style Selector="Button.SecondaryButton">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="14,7"/>
    <Setter Property="CornerRadius" Value="6"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background" Duration="0:0:0.15"/>
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="Button.SecondaryButton:pointerover">
    <Setter Property="Background" Value="{DynamicResource SukiLowColor}"/>
  </Style>

  <Style Selector="Button.DangerButton">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderBrush" Value="#E74C3C"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Foreground" Value="#E74C3C"/>
    <Setter Property="Padding" Value="14,7"/>
    <Setter Property="CornerRadius" Value="6"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background" Duration="0:0:0.15"/>
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="Button.DangerButton:pointerover">
    <Setter Property="Background" Value="#15E74C3C"/>
  </Style>
  <Style Selector="Button.DangerButton:pressed">
    <Setter Property="Background" Value="#25E74C3C"/>
  </Style>

  <Style Selector="Button.SuccessButton">
    <Setter Property="Background" Value="#2ECC71"/>
    <Setter Property="Foreground" Value="White"/>
    <Setter Property="Padding" Value="16,8"/>
    <Setter Property="CornerRadius" Value="6"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Transitions">
      <Transitions>
        <DoubleTransition Property="Opacity" Duration="0:0:0.15"/>
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="Button.SuccessButton:pointerover">
    <Setter Property="Opacity" Value="0.9"/>
  </Style>

  <Style Selector="Button.IconButton">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Padding" Value="8"/>
    <Setter Property="CornerRadius" Value="4"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="MinWidth" Value="32"/>
    <Setter Property="MinHeight" Value="32"/>
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background" Duration="0:0:0.15"/>
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="Button.IconButton:pointerover">
    <Setter Property="Background" Value="{DynamicResource SukiLowColor}"/>
  </Style>

  <!-- Inputs -->
  <Style Selector="TextBox.FormInput">
    <Setter Property="CornerRadius" Value="6"/>
    <Setter Property="FontSize" Value="14"/>
    <Setter Property="Padding" Value="10,8"/>
  </Style>
  <Style Selector="TextBox.SearchBox">
    <Setter Property="CornerRadius" Value="20"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="Padding" Value="14,8"/>
  </Style>

  <!-- Cards — SukiUI compatible with hover transitions -->
  <Style Selector="Border.CustomerCard">
    <Setter Property="Background" Value="{DynamicResource SukiCardBackground}"/>
    <Setter Property="CornerRadius" Value="8"/>
    <Setter Property="Padding" Value="16,14"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="BorderBrush" Value="Transparent"/>
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="BorderBrush" Duration="0:0:0.2"/>
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="Border.CustomerCard:pointerover">
    <Setter Property="BorderBrush" Value="{DynamicResource SukiPrimaryColor}"/>
  </Style>

  <Style Selector="Border.StatCard">
    <Setter Property="Background" Value="{DynamicResource SukiCardBackground}"/>
    <Setter Property="CornerRadius" Value="10"/>
    <Setter Property="Padding" Value="20,16"/>
    <Setter Property="MinWidth" Value="160"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="BorderBrush" Value="Transparent"/>
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="BorderBrush" Duration="0:0:0.2"/>
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="Border.StatCard:pointerover">
    <Setter Property="BorderBrush" Value="{DynamicResource SukiPrimaryColor}"/>
  </Style>

  <Style Selector="Border.ActionCard">
    <Setter Property="Background" Value="{DynamicResource SukiCardBackground}"/>
    <Setter Property="CornerRadius" Value="10"/>
    <Setter Property="Padding" Value="20,16"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="BorderBrush" Value="Transparent"/>
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="BorderBrush" Duration="0:0:0.2"/>
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="Border.ActionCard:pointerover">
    <Setter Property="BorderBrush" Value="{DynamicResource SukiPrimaryColor}"/>
  </Style>

  <!-- Badges -->
  <Style Selector="Border.BadgeSuccess">
    <Setter Property="Background" Value="#1A2ECC71"/>
    <Setter Property="CornerRadius" Value="4"/>
    <Setter Property="Padding" Value="8,3"/>
  </Style>
  <Style Selector="Border.BadgeWarning">
    <Setter Property="Background" Value="#1AF39C12"/>
    <Setter Property="CornerRadius" Value="4"/>
    <Setter Property="Padding" Value="8,3"/>
  </Style>
  <Style Selector="Border.BadgeError">
    <Setter Property="Background" Value="#1AE74C3C"/>
    <Setter Property="CornerRadius" Value="4"/>
    <Setter Property="Padding" Value="8,3"/>
  </Style>
  <Style Selector="Border.BadgeInfo">
    <Setter Property="Background" Value="{DynamicResource SukiCardBackground}"/>
    <Setter Property="CornerRadius" Value="4"/>
    <Setter Property="Padding" Value="8,3"/>
  </Style>
  <Style Selector="Border.BadgeArchived">
    <Setter Property="Background" Value="#1AE74C3C"/>
    <Setter Property="CornerRadius" Value="4"/>
    <Setter Property="Padding" Value="8,3"/>
  </Style>
  <Style Selector="TextBlock.BadgeText">
    <Setter Property="FontSize" Value="11"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Opacity" Value="0.7"/>
  </Style>

  <!-- Separators -->
  <Style Selector="Border.Divider">
    <Setter Property="Height" Value="1"/>
    <Setter Property="Opacity" Value="0.2"/>
    <Setter Property="Margin" Value="0,8"/>
  </Style>

  <!-- Focus indicators for accessibility -->
  <Style Selector="Button:focus-visible">
    <Setter Property="BorderBrush" Value="{DynamicResource SukiPrimaryColor}"/>
    <Setter Property="BorderThickness" Value="2"/>
  </Style>

</Styles>
