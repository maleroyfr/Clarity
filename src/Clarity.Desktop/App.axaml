<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:suki="https://github.com/kikipoulet/SukiUI"
             x:Class="Clarity.Desktop.App"
             xmlns:local="using:Clarity.Desktop"
             xmlns:shell="clr-namespace:Clarity.Desktop.ViewModels.Shell">

    <Application.DataTemplates>
        <!-- SukiSideMenu sets its content to the selected NavPageItem data item.
             This template extracts PageVm so the ViewLocator resolves the real view.
             TransitioningContentControl gives smooth cross-fade on page switch. -->
        <DataTemplate DataType="{x:Type shell:NavPageItem}">
            <TransitioningContentControl Content="{Binding PageVm}">
                <TransitioningContentControl.PageTransition>
                    <CrossFade Duration="0:0:0.2"/>
                </TransitioningContentControl.PageTransition>
            </TransitioningContentControl>
        </DataTemplate>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
        <suki:SukiTheme ThemeColor="Blue" />
        <StyleInclude Source="/Styles/ClarityTheme.axaml"/>
    </Application.Styles>
</Application>